# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=saas_db
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING

# Exchange Rate
IQD_USD_RATE=1450

# Rate Limiting
THROTTLER_TTL=60000
THROTTLER_LIMIT=100

# App
APP_PORT=3000
APP_ENV=development
CORS_ORIGIN=*
FRONTEND_URL=http://localhost:5173

# ZainCash Payment Gateway
ZAINCASH_BASE_URL=https://pg-api-uat.zaincash.iq
ZAINCASH_CLIENT_ID=your-client-id-here
ZAINCASH_CLIENT_SECRET=your-client-secret-here
ZAINCASH_API_KEY=your-api-key-here
ZAINCASH_SERVICE_TYPE=your-service-type-here
